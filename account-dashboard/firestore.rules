rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Check if user is authenticated and exists in users collection
    function isAuthorized() {
      return request.auth != null
        && request.auth.token.email.matches('.*@observepoint\\.com$')
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email));
    }

    // Check if user is an admin
    function isAdmin() {
      return isAuthorized()
        && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin';
    }

    // Users collection - admins can read/write, authorized users can read their own doc
    match /users/{userEmail} {
      // Allow any authenticated @observepoint.com user to read their own doc (needed for bootstrap auth check)
      // Authorized users can read all user docs (needed for admin panel)
      allow read: if isAuthorized()
        || (request.auth != null && request.auth.token.email == userEmail && request.auth.token.email.matches('.*@observepoint\\.com$'));
      allow write: if isAdmin();
      // Allow bootstrap: john.davis@observepoint.com can create their own doc
      allow create: if request.auth != null
        && request.auth.token.email == userEmail
        && request.auth.token.email == 'john.davis@observepoint.com';
      // Allow any authorized user to update their own lastLogin
      allow update: if request.auth != null
        && request.auth.token.email == userEmail
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin']);
    }

    // Account documents - read/write for authorized users
    match /accounts/{accountId} {
      allow read, write: if isAuthorized();

      // Manual tasks subcollection
      match /manualTasks/{taskId} {
        allow read, write: if isAuthorized();
      }
    }

    // Settings collection - global notes, etc.
    match /settings/{docId} {
      allow read, write: if isAuthorized();
    }

    // Tasks - top-level collection (replaces GitHub Project items)
    // See /TASKS_DATA_MODEL.md for schema.
    match /tasks/{taskId} {
      allow read, write: if isAuthorized();

      // Comments are read/write for any authorized user.
      match /comments/{commentId} {
        allow read, write: if isAuthorized();
      }

      // Activity is append-only audit log. Clients can create entries but
      // never modify or delete them. Apps Script writes via service account
      // and bypasses these rules.
      match /activity/{activityId} {
        allow read: if isAuthorized();
        allow create: if isAuthorized();
        allow update, delete: if false;
      }
    }

    // Task configuration documents (saved views, shared enum overrides, etc.)
    match /taskConfig/{docId} {
      allow read, write: if isAuthorized();

      match /views/{viewId} {
        allow read, write: if isAuthorized();
      }
    }

    // Task labels - global, shared across all tasks. Any authorized user can
    // create / rename / recolor / delete. Tasks reference labels via labelIds[].
    match /taskLabels/{labelId} {
      allow read, write: if isAuthorized();
    }
  }
}
